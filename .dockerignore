# AgentKit local cache (ok to ignore)
#.agentkit/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Test / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/

# Coverage
.coverage
coverage.xml
htmlcov/

# Logs / temp
*.log
*.tmp
*.swp
*.swo

# Build outputs
dist/
build/
*.egg-info/
.eggs/

# OS junk
.DS_Store
Thumbs.db

# Environment files (keep ignoring)
.env
.env.*

# Virtual environments
.venv/
venv/
ENV/
env/

# IDE
.vscode/
.idea/
.windsurf/

# Git
.git/